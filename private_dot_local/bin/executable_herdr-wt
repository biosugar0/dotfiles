#!/bin/sh
# git wt で worktree を作成し (wt.copy / wt.hook が適用される)、
# Herdr workspace として開く。Herdr の worktree create は copy/hook を
# 持たないため、作成は git wt・workspace 化は Herdr という分担にする。
#
# 使い方: herdr-wt <branch> [start-point] [--claude]
#   start-point 省略時は origin/main を fetch してベースにする
#   --claude: 開いた workspace の root pane で claude を起動
set -eu

branch="" start_point="" start_claude=false
for a in "$@"; do
	case "$a" in
	--claude) start_claude=true ;;
	-*) echo "herdr-wt: unknown option: $a" >&2; exit 2 ;;
	*)
		if [ -z "$branch" ]; then branch=$a
		elif [ -z "$start_point" ]; then start_point=$a
		fi
		;;
	esac
done
[ -n "$branch" ] || { echo "usage: herdr-wt <branch> [start-point] [--claude]" >&2; exit 2; }

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
	echo "herdr-wt: not in a git repo" >&2
	exit 1
}
repo_root=$(git rev-parse --show-toplevel)

if git show-ref --verify --quiet "refs/heads/$branch"; then
	# 既存ブランチ: そのまま開く (start-point は無視される)
	wt_path=$(git wt --nocd "$branch" 2>/dev/null | tail -1)
else
	if [ -z "$start_point" ] && git remote get-url origin >/dev/null 2>&1; then
		git fetch origin main >/dev/null 2>&1 || true
		git show-ref --verify --quiet refs/remotes/origin/main && start_point=origin/main
	fi
	if [ -n "$start_point" ]; then
		wt_path=$(git wt --nocd "$branch" "$start_point" 2>/dev/null | tail -1)
	else
		wt_path=$(git wt --nocd "$branch" 2>/dev/null | tail -1)
	fi
fi
[ -n "$wt_path" ] && [ -d "$wt_path" ] || {
	echo "herdr-wt: git wt failed for branch $branch" >&2
	exit 1
}

# Herdr workspace 化 (worktree open は親 repo 配下にグルーピングされる)。
# server 不在なら worktree だけ作って終わる。
open_json=$(herdr worktree open --cwd "$repo_root" --path "$wt_path" \
	--label "$branch" --focus --json 2>/dev/null) ||
	open_json=$(herdr workspace create --cwd "$wt_path" --label "$branch" --focus 2>/dev/null) ||
	{
		echo "$wt_path"
		echo "herdr-wt: worktree ready (herdr server not running; workspace not opened)" >&2
		exit 0
	}

if [ "$start_claude" = true ]; then
	# already_open の workspace には起動済みの可能性があるため送らない
	pane=$(printf '%s' "$open_json" | python3 -c '
import sys, json
r = json.load(sys.stdin)["result"]
print("" if r.get("already_open") else r["root_pane"]["pane_id"])
' 2>/dev/null || true)
	[ -n "$pane" ] && herdr pane run "$pane" "claude"
fi

echo "$wt_path"
