#!/bin/sh
# 長時間コマンドを Herdr の agent としてサイドバーに載せるラッパー。
# working で開始し、成功なら idle (UI 上は未読の done)、失敗なら blocked に
# 遷移させる。blocked は attention queue とサウンド通知の対象になるので、
# ビルド・テスト・deploy の失敗が Claude の応答待ちと同じ受信箱に入る。
#
# 使い方: herdr-watch [--label NAME] -- <command...>
#   例:   herdr pane run "$PANE" "herdr-watch --label e2e -- npm run test:e2e"
set -u

label=""
while [ $# -gt 0 ]; do
	case "$1" in
	--label)
		label=${2:?"herdr-watch: --label requires a value"}
		shift 2
		;;
	--)
		shift
		break
		;;
	*) break ;;
	esac
done
[ $# -gt 0 ] || { echo "usage: herdr-watch [--label NAME] -- <command...>" >&2; exit 2; }
[ -n "$label" ] || label=$(basename "$1")

report() {
	# Herdr 外や server 停止時は黙って素通しする (コマンド実行自体は続行)
	[ "${HERDR_ENV:-}" = "1" ] && [ -n "${HERDR_PANE_ID:-}" ] || return 0
	command -v herdr >/dev/null 2>&1 || return 0
	herdr pane report-agent "$HERDR_PANE_ID" --source herdr-watch \
		--agent "$label" --state "$1" --message "$2" >/dev/null 2>&1 || true
}

report working "$*"
"$@"
rc=$?
if [ "$rc" -eq 0 ]; then
	report idle "done: $* (rc=0)"
else
	report blocked "FAILED: $* (rc=$rc)"
fi
exit "$rc"
